{
  "name": "whisper-desktop",
  "version": "1.0.0",
  "description": "Offline Vietnamese audio transcription desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
